{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contract-negotiation.json",
  "title": "Contract Negotiations Value",
  "description": "Adds a property containing the status of a corresponding EDC Contract Negotiation.",
  "type": "object",
  "properties": {
    "contractNegotiation": {
      "type" : "object",
      "properties": {
        "isPending": {
          "type": "boolean"
        },
        "isLeased": {
          "type": "boolean"
        },
        "correlationId": {
          "type": "string"
        },
        "counterPartyAddress": {
          "type": "string"
        },
        "state": {
          "type": "string",
          "enum": [
            "INITIAL", "REQUESTING", "REQUESTED", "OFFERING", "OFFERED", "ACCEPTING", "ACCEPTED",
            "AGREEING", "AGREED", "VERIFYING", "VERIFIED", "FINALIZING", "FINALIZED", "TERMINATING", "TERMINATED"
          ]
        }
      }
    }
  }
}