{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contract-negotiation.json",
  "title": "Contract Negotiations Value",
  "description": "Adds a property containing the status of a corresponding EDC Contract Negotiation.",
  "type": "object",
  "properties": {
    "contractNegotiation": {
      "type" : "object",
      "properties": {
        "isPending": {
          "type": "boolean"
        },
        "isLeased": {
          "type": "boolean"
        },
        "state": {
          "type": "string",
          "enum": [
            "initial", "requesting", "requested", "offering", "offered", "accepting", "terminated",
            "accepted", "agreeing", "agreed", "verifying", "verified", "finalizing", "terminating"
          ]
        }
      }
    }
  }
}