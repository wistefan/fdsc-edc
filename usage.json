{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "usage.json",
  "title": "Usage Extension",
  "description": "Extensions of a usage to allow dsp mapping.",
  "type": "object",
  "properties": {
    "externalId": {
      "type": "string"
    },
    "transferState": {
      "type": "string",
      "enum": ["INITIAL","PROVISIONING","PROVISIONING_REQUESTED","PROVISIONED","REQUESTING","REQUESTED","STARTING","STARTUP_REQUESTED","STARTED","SUSPENDING",
        "SUSPENDING_REQUESTED","SUSPENDED","RESUMING","RESUMED","COMPLETING","COMPLETING_REQUESTED","COMPLETED","TERMINATING","TERMINATING_REQUESTED","TERMINATED",
        "DEPROVISIONING", "DEPROVISIONING_REQUESTED", "DEPROVISIONED" ]
    }
  },
  "required": ["externalId", "transferState"]
}